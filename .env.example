# Supabase settings used by Netlify Functions.
# Configure real values in Netlify environment variables.
# Use the project URL and anon key. Do not commit service role keys.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# GitHub Actions RSS analyzer settings.
# Configure real values in GitHub Actions secrets, not in this file.
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-2.5-flash
